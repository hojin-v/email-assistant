# ============================================
# 1. 서버 실행 환경
# ============================================
RAG_ENV=local
RAG_HOST=0.0.0.0
RAG_PORT=8090
MOCK_MODE=false

# ============================================
# 2. 생성 LLM API 설정
# ============================================
LLM_API_BASE_URL=http://cellm.gachon.ac.kr:8000/v1
LLM_API_KEY=
LLM_CHAT_MODEL=text
LLM_API_TIMEOUT_SECONDS=60

# ============================================
# 3. 임베딩 API 설정
# ============================================
EMBEDDING_API_BASE_URL=http://cellm.gachon.ac.kr:8000/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=embedding
EMBEDDING_BACKEND=embedding_api
EMBEDDING_DIMENSIONS=384

# ============================================
# 4. 벡터 저장소 설정
# ============================================
# 로컬 단독 실행 기본값: RAG 컨테이너/프로세스 내부의 Chroma persistent storage를 사용한다.
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIRECTORY=.rag-data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false

# 배포 권장값: 별도 ChromaDB 서버/서비스를 HTTP client로 사용한다.
# VECTOR_BACKEND=chroma_http
# CHROMA_HOST=chromadb.<namespace>.svc.cluster.local
# CHROMA_PORT=8000
# CHROMA_SSL=false

# ============================================
# 5. 문서 분할 설정
# ============================================
CHUNKING_BACKEND=langchain
PDF_CHUNKING_STRATEGY=semantic

# ============================================
# 6. 검색 / 업로드 기본값
# ============================================
DEFAULT_TOP_K=5
DEFAULT_CHUNK_SIZE=900
DEFAULT_CHUNK_OVERLAP=120
MAX_UPLOAD_BYTES=10485760

# ============================================
# 6-1. PDF OCR fallback 설정
# ============================================
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGES=kor
PDF_OCR_DPI=300

# ============================================
# 7. RabbitMQ worker 설정
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_HEARTBEAT_SECONDS=60
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT_SECONDS=30
EXCHANGE_APP_TO_RAG=x.app2rag.direct
EXCHANGE_RAG_TO_APP=x.rag2app.direct
QUEUE_KNOWLEDGE_INGEST_INBOUND=q.2rag.knowledge.ingest
QUEUE_TEMPLATE_INDEX_INBOUND=q.2rag.templates.index
QUEUE_TEMPLATE_MATCH_INBOUND=q.2rag.templates.match
QUEUE_DRAFT_INBOUND=q.2rag.draft
QUEUE_DLX_FAILED=q.dlx.failed
ROUTING_KEY_KNOWLEDGE_INGEST_INBOUND=2rag.knowledge.ingest
ROUTING_KEY_TEMPLATE_INDEX_INBOUND=2rag.templates.index
ROUTING_KEY_TEMPLATE_MATCH_INBOUND=2rag.templates.match
ROUTING_KEY_DRAFT_INBOUND=2rag.draft
ROUTING_KEY_KNOWLEDGE_INGEST_RESULT=2app.knowledge.ingest
ROUTING_KEY_TEMPLATE_INDEX_RESULT=2app.templates.index
ROUTING_KEY_TEMPLATE_MATCH_RESULT=2app.templates.match
ROUTING_KEY_DRAFT_RESULT=2app.rag.draft
ROUTING_KEY_RAG_PROGRESS=2app.rag.progress
RABBITMQ_MAX_RETRY_COUNT=3
