# ------------------------------------------------------------
# EmailAssist Frontend 환경변수 예시
# ------------------------------------------------------------
# VITE_* 값은 Vite 빌드 시점에 프론트 JS 번들에 포함됩니다.
# Docker/nginx 운영 배포에서는 컨테이너 실행 시점에 바꿔도 이미 빌드된 JS에는 반영되지 않습니다.
# 운영 배포 값은 Dockerfile ARG 또는 GitHub Actions build-args에서 관리하세요.

# [운영/로컬 공통] 브라우저가 실제 API 요청을 보낼 백엔드 주소입니다.
# 비워두면 현재 프론트 origin 기준으로 /api/... 를 호출합니다.
# 로컬에서 Vite proxy를 쓸 때는 비워두는 것을 권장합니다.
# 운영에서 nginx 프록시를 쓰지 않는다면 https://capstone.studylink.click 처럼 명시하세요.
VITE_API_BASE_URL=

# [운영/로컬 공통] 관리자 API를 일반 백엔드와 다른 도메인으로 호출할 때 사용합니다.
# 비워두면 VITE_API_BASE_URL 값을 따라갑니다.
# 운영에서 nginx 프록시를 쓰지 않는다면 https://admin.studylink.click 처럼 명시하세요.
VITE_ADMIN_API_BASE_URL=

# [운영/로컬 공통] 브라우저가 SSE 연결을 보낼 주소입니다.
# 비워두면 현재 프론트 origin 기준으로 /sse/connect 를 호출합니다.
# 운영에서 nginx 프록시를 쓰지 않는다면 https://capstone.studylink.click 처럼 명시하세요.
VITE_SSE_BASE_URL=

# [로컬 개발 전용] npm run dev 실행 시 Vite 개발 서버가 /api 요청을 넘길 대상입니다.
# 운영 Docker/nginx 배포에서는 사용되지 않습니다.
VITE_BACKEND_ORIGIN=http://localhost:8080

# [로컬 개발 전용] npm run dev 실행 시 Vite 개발 서버가 /sse 요청을 넘길 대상입니다.
# 운영 Docker/nginx 배포에서는 사용되지 않습니다.
VITE_SSE_ORIGIN=http://localhost:8081

# [운영/로컬 공통] true이면 일부 흐름에서 데모 데이터를 사용합니다.
# 실서비스 배포에서는 false로 유지하세요.
VITE_DEMO_MODE=false
